rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
      match /bookings/{bookingId} {
        // Allow users to read all bookings to check availability
        // Note: Future enhancement could limit individual document fields
        allow read: if request.auth != null;
        allow update, delete: if request.auth != null && (
          request.auth.uid == resource.data.userId || 
          request.auth.token.email == 'anthony@offgridmediagroup.com'
        );
        allow create: if request.auth != null;
      }
      
      // Default rule for other collections (if any)
      match /{document=**} {
        allow read, write: if request.time < timestamp.date(2026, 4, 30);
      }
  }
}
