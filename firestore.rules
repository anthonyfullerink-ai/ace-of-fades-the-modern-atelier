rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
      match /bookings/{bookingId} {
        // Allow users to read all bookings to check availability
        // Note: Future enhancement could limit individual document fields
        allow read: if request.auth != null;
        allow update, delete: if request.auth != null && (
          request.auth.uid == resource.data.userId || 
          request.auth.token.email in ['anthony@offgridmediagroup.com', 'admin@offgridmediagroup.com']
        );
        allow create: if request.auth != null;
      }

      match /login_logs/{logId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null && request.auth.token.email == 'anthony@offgridmediagroup.com';
      }

      match /daily_stats/{date} {
        allow create, update: if true;
        allow read: if request.auth != null && (
          request.auth.token.email in ['anthony@offgridmediagroup.com', 'admin@offgridmediagroup.com']
        );
      }
      
      match /reviews/{reviewId} {
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
        allow read: if request.auth != null && (
          request.auth.token.email in ['anthony@offgridmediagroup.com', 'admin@offgridmediagroup.com'] ||
          request.auth.uid == resource.data.userId
        );
        allow update, delete: if request.auth != null && request.auth.token.email in ['anthony@offgridmediagroup.com', 'admin@offgridmediagroup.com'];
      }
      
      // Default rule for other collections (if any)
      match /{document=**} {
        allow read, write: if request.time < timestamp.date(2026, 4, 30);
      }
  }
}
